# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=
# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=sk-your-openai-key-here
GEMINI_MODEL=gpt-4o
GEMINI_MAX_TOKENS=2000
GEMINI_TEMPERATURE=0.2

# ─── AI Behaviour ─────────────────────────────────────────────────────────────
AI_MAX_RETRIES=3
AI_RETRY_DELAY_MS=1500

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info


CORS_ORIGIN=https://ecomart-frontend.vercel.app
